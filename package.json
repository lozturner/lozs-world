{
  "name": "lozs-world",
  "version": "0.1.0",
  "private": true,
  "description": "Tron-style local 3D environment with up-to-five live web monitors and STL drag-drop.",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node20-win-x64 --output dist/LozsWorld.exe --compress GZip"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "es-module-shims": "^1.10.0",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.0",
    "three": "0.160.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1"
  },
  "pkg": {
    "scripts": [
      "server.js"
    ],
    "assets": [
      "public/**/*",
      "node_modules/three/build/**/*",
      "node_modules/three/examples/jsm/**/*",
      "node_modules/es-module-shims/dist/**/*"
    ]
  }
}
